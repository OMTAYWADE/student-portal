<!DOCTYPE html>
<html>
<head>
<title><%= typeof title !== "undefined" ? title : "Campus Assistant" %></title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<style>
<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Inter',sans-serif;
background:#f1f5f9;
color:#0f172a;
display:flex;
min-height:100vh;
}

/* SIDEBAR */

.sidebar{
width:240px;
background:#020617;
color:white;
padding:30px 20px;
display:flex;
flex-direction:column;
justify-content:space-between;
transition:0.3s;
}

.sidebar h2{
font-size:18px;
margin-bottom:30px;
}

.sidebar a{
display:block;
text-decoration:none;
color:#94a3b8;
margin-bottom:14px;
font-size:14px;
padding:8px 10px;
border-radius:8px;
transition:0.2s;
}

.sidebar a:hover{
background:#1e293b;
color:white;
}

/* MAIN */

.main{
flex:1;
padding:40px;
}

/* TOPBAR */

.topbar{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:35px;
}

.topbar h2{
font-size:24px;
font-weight:600;
}

.profile img{
width:42px;
height:42px;
border-radius:50%;
}

/* SUMMARY GRID */

.summary{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-bottom:35px;
}

.card{
background:white;
padding:22px;
border-radius:14px;
box-shadow:0 10px 25px rgba(0,0,0,0.05);
transition:0.3s;
}

.card:hover{
transform:translateY(-6px);
box-shadow:0 15px 35px rgba(0,0,0,0.08);
}

.card h3{
font-size:13px;
color:#64748b;
margin-bottom:8px;
}

.card p{
font-size:26px;
font-weight:600;
}

/* PROGRESS */

.progress-wrap{
margin-top:10px;
height:8px;
background:#e2e8f0;
border-radius:8px;
overflow:hidden;
}

.progress-bar{
height:8px;
background:linear-gradient(90deg,#22c55e,#16a34a);
width:0%;
transition:width 0.6s ease;
}

/* FILTER BAR */

.filter-bar{
margin-bottom:20px;
display:flex;
flex-wrap:wrap;
gap:10px;
}

.filter-btn{
padding:6px 14px;
border-radius:20px;
border:none;
background:#e2e8f0;
cursor:pointer;
font-size:12px;
}

.filter-btn.active{
background:#0f172a;
color:white;
}

/* ASSIGNMENTS */

.assignment-container{
background:white;
border-radius:14px;
box-shadow:0 8px 20px rgba(0,0,0,0.05);
padding:10px 25px;
}

.assignment{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 0;
border-bottom:1px solid #f1f5f9;
transition:0.2s;
}

.assignment:hover{
background:#f8fafc;
padding-left:10px;
padding-right:10px;
border-radius:10px;
}

.assignment:last-child{
border-bottom:none;
}

.assignment-info{
display:flex;
flex-direction:column;
gap:4px;
}

.assignment-info strong{
font-size:15px;
}

.assignment-info small{
font-size:13px;
color:#64748b;
}

/* BADGES */

.badge{
padding:5px 12px;
border-radius:20px;
font-size:12px;
font-weight:500;
}

.badge.pending{
background:#fef3c7;
color:#92400e;
}

.badge.done{
background:#dcfce7;
color:#166534;
}

.badge.overdue{
background:#fee2e2;
color:#b91c1c;
}

/* BUTTONS */

.btn{
padding:6px 12px;
border:none;
border-radius:8px;
cursor:pointer;
font-size:12px;
margin-left:8px;
}

.btn-complete{
background:#22c55e;
color:white;
}

.btn-undo{
background:#ef4444;
color:white;
}

.btn:hover{
opacity:0.85;
}

/* RESPONSIVE */

@media(max-width:900px){

body{
flex-direction:column;
}

.sidebar{
width:100%;
flex-direction:row;
align-items:center;
justify-content:space-between;
padding:15px 20px;
}

.sidebar h2{
margin:0;
}

.sidebar div{
display:flex;
gap:15px;
}

.main{
padding:20px;
}

.summary{
grid-template-columns:repeat(auto-fit,minmax(150px,1fr));
}

.assignment{
flex-direction:column;
align-items:flex-start;
gap:10px;
}

}

</style>

</style>
</head>

<body>

<div class="navbar">

  <div>
    <a href="/" style="font-weight:700;font-size:18px;">
      🎓 Campus Assistant
    </a>
  </div>

  <div class="nav-links">
    <a href="/notes">Notes Hub</a>
    <a href="/notes/browse">Browse</a>
    <% if(user){ %>
      <a href="/notes/dashboard">Dashboard</a>
      <a href="/upload-notes">Upload</a>
      <a href="/logout">Logout</a>
    <% } else { %>
      <a href="/auth/google">Login</a>
    <% } %>
  </div>

</div>

<div class="container">
  <%- body %>
</div>

<div class="footer">
  © <%= new Date().getFullYear() %> Campus Assistant • Built for Students 🚀
</div>

</body>
</html>