<!DOCTYPE html>
<html>
<head>
<title>Campus Assistant</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Inter',sans-serif;
background:#0f172a;
color:white;
overflow-x:hidden;
}

/* NAVBAR */

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 60px;
backdrop-filter:blur(12px);
background:rgba(255,255,255,0.05);
position:sticky;
top:0;
z-index:100;
}

.logo{
font-weight:800;
font-size:20px;
background:linear-gradient(90deg,#7c3aed,#06b6d4);
-webkit-background-clip:text;
color:transparent;
}

.nav-links a{
text-decoration:none;
color:#cbd5f5;
margin-left:25px;
font-weight:500;
transition:0.3s;
}

.nav-links a:hover{
color:#22d3ee;
}

/* HERO */

.hero{
padding:120px 30px;
text-align:center;
background:linear-gradient(-45deg,#7c3aed,#06b6d4,#9333ea,#0ea5e9);
background-size:400% 400%;
animation:gradientMove 12s ease infinite;
}

@keyframes gradientMove{
0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}
}

.hero h1{
font-size:48px;
font-weight:800;
margin-bottom:20px;
}

.hero p{
max-width:700px;
margin:auto;
opacity:0.9;
font-size:18px;
}

.hero-btn{
margin-top:40px;
padding:15px 35px;
border:none;
border-radius:12px;
font-size:15px;
font-weight:600;
cursor:pointer;
background:white;
color:#7c3aed;
transition:0.3s;
}

.hero-btn:hover{
transform:translateY(-4px);
box-shadow:0 15px 35px rgba(0,0,0,0.25);
}

/* SECTION */

.section{
max-width:1200px;
margin:90px auto;
padding:0 30px;
}

.section h2{
margin-bottom:40px;
font-size:28px;
}

/* CARDS */

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:30px;
}

.card{
background:rgba(255,255,255,0.05);
border-radius:20px;
padding:30px;
backdrop-filter:blur(10px);
transition:0.3s;
position:relative;
overflow:hidden;
}

.card::before{
content:'';
position:absolute;
width:200%;
height:200%;
background:linear-gradient(120deg,transparent,rgba(255,255,255,0.1),transparent);
top:-50%;
left:-50%;
transform:rotate(25deg);
opacity:0;
transition:0.6s;
}

.card:hover::before{
opacity:1;
left:120%;
}

.card:hover{
transform:translateY(-10px);
}

.card h3{
margin-bottom:10px;
font-size:18px;
}

.card p{
color:#cbd5f5;
font-size:14px;
}

/* FLOATING ICON */

.floating{
animation:float 5s ease-in-out infinite;
}

@keyframes float{
0%{transform:translateY(0px)}
50%{transform:translateY(-10px)}
100%{transform:translateY(0px)}
}

/* FOOTER */

footer{
text-align:center;
padding:40px;
background:#020617;
margin-top:80px;
color:#94a3b8;
}

footer a{
color:#cbd5f5;
text-decoration:none;
margin:0 10px;
}

footer a:hover{
color:#22d3ee;
}

@media(max-width:768px){

.navbar{
padding:18px 25px;
}

.hero h1{
font-size:34px;
}

}

</style>
</head>

<body>

<div class="navbar">

<div class="logo">🎓 Campus Assistant</div>

<div class="nav-links">
<a href="/">Home</a>
<a href="/busform">Bus Concession</a>

<% if(!user){ %>
<a href="/auth/google">Login</a>
<% } else { %>
<a href="/dashboard">Dashboard</a>
<a href="/logout">Logout</a>
<% } %>

</div>

</div>


<div class="hero">

<h1>Smart Digital Campus Portal</h1>

<p>
Track academics, manage campus services and stay updated with
real-time announcements — all in one platform.
</p>

<% if(!user){ %>

<a href="/auth/google">
<button class="hero-btn floating">Connect Google Classroom</button>
</a>

<% } else { %>

<a href="/dashboard">
<button class="hero-btn floating">Go to Dashboard</button>
</a>

<% } %>

</div>


<div class="section">

<h2>🚀 Portal Features</h2>

<div class="grid">

<div class="card">
<h3>📊 Academic Dashboard</h3>
<p>Track assignments, submissions and deadlines from one place.</p>
</div>

<div class="card">
<h3>🚌 Bus Concession</h3>
<p>Apply and download your transport concession forms instantly.</p>
</div>

<div class="card">
<h3>📢 Announcements</h3>
<p>Receive real-time academic updates and important notices.</p>
</div>

<div class="card">
<h3>🔐 Google Login</h3>
<p>Secure login with Google and automatic classroom sync.</p>
</div>

</div>

</div>


<footer>

<a href="/privacy">Privacy Policy</a>
|
<a href="/terms">Terms</a>

<br><br>

© 2026 Campus Assistant

</footer>

</body>
</html>