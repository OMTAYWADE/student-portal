<!DOCTYPE html>
<html>

<head>
<title>Campus Assistant</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Inter',sans-serif;
background:#0f172a;
color:white;
}

/* NAVBAR */

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 40px;
background:#020617;
border-bottom:1px solid rgba(255,255,255,0.08);
}

.logo{
font-size:20px;
font-weight:700;
color:#6366f1;
}

.nav-links{
display:flex;
gap:22px;
}

.nav-links a{
color:#94a3b8;
text-decoration:none;
font-size:14px;
}

.nav-links a:hover{
color:white;
}

/* HERO */

.hero{
padding:100px 20px;
text-align:center;
background:linear-gradient(135deg,#6366f1,#9333ea);
}

.hero h1{
font-size:48px;
margin-bottom:20px;
}

.hero p{
font-size:18px;
opacity:0.9;
max-width:650px;
margin:auto;
margin-bottom:30px;
}

.hero-btn{
background:white;
color:#4f46e5;
padding:14px 28px;
border-radius:10px;
font-weight:600;
text-decoration:none;
}

/* FEATURES */

.section{
padding:80px 20px;
max-width:1100px;
margin:auto;
}

.section h2{
text-align:center;
margin-bottom:40px;
font-size:30px;
}

.features{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.feature-card{
background:#020617;
padding:30px;
border-radius:14px;
border:1px solid rgba(255,255,255,0.06);
transition:.3s;
}

.feature-card:hover{
transform:translateY(-5px);
border-color:#6366f1;
}

.feature-card h3{
margin-bottom:10px;
}

/* ABOUT */

.about{
text-align:center;
max-width:800px;
margin:auto;
opacity:0.9;
}

/* FOOTER */

.footer{
margin-top:60px;
text-align:center;
padding:25px;
font-size:13px;
color:#94a3b8;
border-top:1px solid rgba(255,255,255,0.08);
}

</style>
</head>

<body>

<!-- NAVBAR -->

<div class="navbar">

<div class="logo">🎓 Campus Assistant</div>

<div class="nav-links">

<a href="/">Home</a>
<a href="/busform">Bus Concession</a>

<% if(user){ %>
<a href="/dashboard">Dashboard</a>
<a href="/logout">Logout</a>
<% } else { %>
<a href="/auth/google">Login</a>
<% } %>

</div>

</div>


<!-- HERO -->

<div class="hero">

<h1>Smart Digital Campus Portal</h1>

<p>
A unified platform for students to manage assignments, courses,
results and campus services in one place.
</p>

<% if(!user){ %>

<a href="/auth/google" class="hero-btn">
Connect Google Classroom
</a>

<% } else { %>

<a href="/dashboard" class="hero-btn">
Go to Dashboard
</a>

<% } %>

</div>


<!-- FEATURES -->

<div class="section">

<h2>🚀 Portal Features</h2>

<div class="features">

<div class="feature-card">
<h3>📚 Course Dashboard</h3>
<p>Track your Google Classroom courses and assignments easily.</p>
</div>

<div class="feature-card">
<h3>📊 Academic Results</h3>
<p>Upload your semester result PDF and analyze your performance.</p>
</div>

<div class="feature-card">
<h3>🚌 Bus Concession</h3>
<p>Download and manage student transport concession forms.</p>
</div>

<div class="feature-card">
<h3>📝 Notes Hub</h3>
<p>Browse and upload notes shared by students.</p>
</div>

</div>

</div>


<!-- ABOUT -->

<div class="section about">

<h2>Why Campus Assistant?</h2>

<p>
Campus Assistant is designed to simplify student life by combining
academic tracking, classroom integration and campus services
into one powerful portal.
</p>

</div>


<!-- FOOTER -->

<div class="footer">

© 2026 Campus Assistant • Built for Students 🚀

</div>

</body>
</html>