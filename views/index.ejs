<!DOCTYPE html>
<html>

<head>
<title>Campus Assistant | Courses</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Inter',sans-serif;
background:#f4f6fb;
min-height:100vh;
color:#1e293b;
display:flex;
flex-direction:column;
}

/* NAVBAR */

.navbar{
background:white;
padding:16px 40px;
display:flex;
justify-content:space-between;
align-items:center;
box-shadow:0 6px 20px rgba(0,0,0,0.05);
}

.logo{
font-weight:700;
font-size:18px;
color:#6366f1;
}

.nav-links{
display:flex;
gap:20px;
}

.nav-links a{
text-decoration:none;
font-size:14px;
color:#475569;
font-weight:500;
}

.nav-links a:hover{
color:#6366f1;
}

/* MAIN CONTAINER */

.container{
max-width:1200px;
margin:auto;
padding:50px 20px;
flex:1;
}

h1{
font-size:28px;
font-weight:600;
margin-bottom:40px;
}

/* GRID */

.courses-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
gap:30px;
}

/* COURSE CARD */

.course-card{
background:white;
border-radius:20px;
overflow:hidden;
box-shadow:0 15px 35px rgba(0,0,0,0.06);
transition:transform .3s ease,box-shadow .3s ease;
display:flex;
flex-direction:column;
}

.course-card:hover{
transform:translateY(-8px);
box-shadow:0 25px 50px rgba(0,0,0,0.1);
}

/* HEADER */

.course-header{
padding:25px;
display:flex;
justify-content:space-between;
align-items:center;
color:white;
background:linear-gradient(135deg,#6366f1,#22c55e);
}

.course-info h3{
font-size:20px;
margin-bottom:4px;
}

.course-info p{
font-size:13px;
opacity:0.9;
}

/* PROFESSOR IMAGE */

.professor{
width:42px;
height:42px;
border-radius:50%;
border:2px solid rgba(255,255,255,0.6);
object-fit:cover;
}

/* BODY */

.course-body{
padding:25px;
flex:1;
display:flex;
flex-direction:column;
justify-content:space-between;
}

/* STATS */

.stats{
display:flex;
justify-content:space-between;
font-size:14px;
margin-bottom:18px;
color:#475569;
}

/* PROGRESS */

.progress-wrap{
height:8px;
background:#e2e8f0;
border-radius:10px;
overflow:hidden;
margin-bottom:20px;
}

.progress-bar{
height:8px;
background:#22c55e;
}

/* ACTIONS */

.actions{
display:flex;
gap:10px;
}

.btn{
flex:1;
text-align:center;
padding:9px;
border-radius:10px;
text-decoration:none;
font-size:13px;
font-weight:500;
}

.btn-primary{
background:#6366f1;
color:white;
}

.btn-secondary{
background:#f1f5f9;
color:#1e293b;
}

.btn-primary:hover{
background:#4f46e5;
}

.btn-secondary:hover{
background:#e2e8f0;
}

/* FOOTER */

.footer{
background:white;
padding:18px;
text-align:center;
font-size:13px;
color:#64748b;
box-shadow:0 -5px 20px rgba(0,0,0,0.05);
}

/* MOBILE */

@media(max-width:600px){

.container{
padding:30px 15px;
}

.course-header{
flex-direction:column;
align-items:flex-start;
gap:10px;
}

.professor{
align-self:flex-end;
}

}

</style>
</head>

<body>

<!-- NAVBAR -->

<div class="navbar">

<div class="logo">🎓 Campus Assistant</div>

<div class="nav-links">

<a href="/">Home</a>
<a href="/notes">Notes Hub</a>
<a href="/notes/browse">Browse</a>

<% if(user){ %>
<a href="/dashboard">Dashboard</a>
<a href="/logout">Logout</a>
<% } else { %>
<a href="/auth/google">Login</a>
<% } %>

</div>

</div>


<!-- CONTENT -->

<div class="container">

<h1>📚 Your Courses</h1>

<div class="courses-grid">

<% courses.forEach(course=> { %>

<div class="course-card">

<div class="course-header"

style="<%= course.backgroundImageUrl 
? `background:url('${course.backgroundImageUrl}') center/cover`
: `background:${course.backgroundColor || 'linear-gradient(135deg,#6366f1,#22c55e)'}` %>">

<div class="course-info">

<h3><%= course.name %></h3>

<p><%= course.section || "No Section" %></p>

</div>

<img src="<%= course.teacherPhoto || 'https://i.pravatar.cc/100' %>" class="professor">

</div>

<div class="course-body">

<div>

<div class="stats">

<span>📄 <%= course.total %> Tasks</span>

<span>⏳ <%= course.pending %> Pending</span>

<span>✅ <%= course.completed %> Done</span>

</div>

<div class="progress-wrap">

<div class="progress-bar" style="width:<%= course.progress || 0 %>%"></div>

</div>

</div>

<div class="actions">

<a href="/assignments?course=<%= course.name %>" class="btn btn-primary">
View Tasks
</a>

<a href="<%= course.alternateLink %>" target="_blank" class="btn btn-secondary">
Open Classroom
</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>


<!-- FOOTER -->

<div class="footer">
© 2026 Campus Assistant • Built for Students 🚀
</div>

</body>

</html>