<!DOCTYPE html>
<html>

<head>
<title>Campus Exchange | Campus Assistant</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

*{margin:0;padding:0;box-sizing:border-box;}

body{
font-family:'Inter',sans-serif;
background:linear-gradient(135deg,#0f172a,#020617);
color:white;
min-height:100vh;
}

/* NAVBAR */

.navbar{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 40px;
background:rgba(255,255,255,0.04);
border-bottom:1px solid rgba(255,255,255,0.08);
}

.navbar h2{
font-size:18px;
}

.navbar a{
color:#cbd5f5;
text-decoration:none;
font-size:14px;
}

/* HERO */

.hero{
text-align:center;
padding:50px 20px;
}

.hero h1{
font-size:36px;
margin-bottom:10px;
}

.hero p{
color:#94a3b8;
}

/* CONTAINER */

.container{
max-width:1200px;
margin:auto;
padding:30px 20px;
}

/* GRID */

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
}

/* CARD */

.card{
background:rgba(255,255,255,0.05);
border-radius:16px;
padding:18px;
border:1px solid rgba(255,255,255,0.08);
transition:0.3s;
}

.card:hover{
transform:translateY(-5px);
}

.card img{
width:100%;
height:160px;
object-fit:cover;
border-radius:12px;
margin-bottom:10px;
}

/* ITEM TITLE */

.card h3{
font-size:16px;
margin-bottom:5px;
}

/* META */

.meta{
font-size:12px;
color:#94a3b8;
margin-bottom:8px;
}

/* PRICE */

.price{
font-size:18px;
font-weight:600;
color:#22c55e;
margin-bottom:10px;
}

/* BUTTON */

.btn{
display:block;
text-align:center;
padding:8px;
border-radius:8px;
background:linear-gradient(135deg,#6366f1,#4f46e5);
color:white;
text-decoration:none;
font-size:13px;
}

/* RESPONSIVE */

@media(max-width:700px){

.hero h1{
font-size:26px;
}

}

</style>

</head>

<body>

<div class="navbar">

<h2>📦 Campus Exchange</h2>

<a href="/sell-item">Sell Item</a>

</div>

<div class="hero">

<h1>Student Marketplace</h1>

<p>Buy and sell study related items within your campus</p>

</div>

<div class="container">

<div class="grid">

<% items.forEach(item=>{ %>

<div class="card">

<img src="/<%= item.images[0] %>">

<h3><%= item.title %></h3>

<div class="meta">
Condition: <%= item.condition %>
</div>

<div class="meta">
Seller: <%= item.sellerName %>
</div>

<div class="price">
₹<%= item.price %>
</div>

<a href="/item/<%= item._id %>" class="btn">
View Item
</a>

</div>

<% }) %>

</div>

</div>

</body>
</html>