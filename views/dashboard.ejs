<!DOCTYPE html>
<html>
<head>
<title>Campus Assistant | Courses</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Inter',sans-serif;
background:linear-gradient(135deg,#0f172a,#020617);
color:#e2e8f0;
min-height:100vh;
display:flex;
flex-direction:column;
}

/* NAVBAR */

.navbar{
background:#020617;
padding:16px 40px;
display:flex;
justify-content:space-between;
align-items:center;
border-bottom:1px solid rgba(255,255,255,0.08);
}

.logo{
font-weight:600;
font-size:18px;
color:#6366f1;
}

.nav-links{
display:flex;
gap:20px;
}

.nav-links a{
color:#94a3b8;
text-decoration:none;
font-size:14px;
transition:0.2s;
}

.nav-links a:hover{
color:white;
}

/* PAGE WRAPPER */

.wrapper{
flex:1;
display:flex;
}

/* SIDEBAR */

.sidebar{
width:230px;
background:#020617;
padding:30px 20px;
border-right:1px solid rgba(255,255,255,0.05);
}

.sidebar h2{
font-size:18px;
margin-bottom:25px;
}

.sidebar a{
display:block;
color:#94a3b8;
text-decoration:none;
margin-bottom:14px;
padding:8px 10px;
border-radius:8px;
transition:0.2s;
font-size:14px;
}

.sidebar a:hover{
background:rgba(99,102,241,0.15);
color:#6366f1;
}

/* MAIN */

.main{
flex:1;
padding:50px;
}

/* HEADER */

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:40px;
}

.header h1{
font-size:26px;
}

.profile img{
width:42px;
height:42px;
border-radius:50%;
border:2px solid #6366f1;
}

/* GRID */

.courses-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
gap:25px;
}

/* CARD */

.course-card{
background:#020617;
border-radius:16px;
border:1px solid rgba(255,255,255,0.05);
overflow:hidden;
transition:0.3s;
}

.course-card:hover{
transform:translateY(-6px);
border-color:#6366f1;
}

/* HEADER */

.course-header{
padding:25px;
display:flex;
justify-content:space-between;
align-items:center;
background:linear-gradient(135deg,#6366f1,#4f46e5);
}

.course-title{
font-size:18px;
font-weight:600;
}

.course-section{
font-size:13px;
opacity:0.85;
margin-top:4px;
}

/* PROFESSOR */

.professor{
width:38px;
height:38px;
border-radius:50%;
border:2px solid rgba(255,255,255,0.4);
object-fit:cover;
}

/* BODY */

.course-body{
padding:22px;
}

.stats{
display:flex;
justify-content:space-between;
font-size:13px;
margin-bottom:15px;
color:#cbd5f5;
}

.progress-wrap{
height:8px;
background:rgba(255,255,255,0.08);
border-radius:10px;
overflow:hidden;
margin-bottom:18px;
}

.progress-bar{
height:8px;
background:linear-gradient(90deg,#6366f1,#22d3ee);
}

.actions{
display:flex;
gap:10px;
}

.btn{
flex:1;
text-align:center;
padding:9px;
border-radius:10px;
font-size:13px;
text-decoration:none;
transition:0.3s;
}

.btn-primary{
background:linear-gradient(135deg,#6366f1,#4f46e5);
color:white;
}

.btn-secondary{
background:rgba(255,255,255,0.08);
color:#e2e8f0;
}

.btn-secondary:hover{
background:rgba(255,255,255,0.15);
}

/* FOOTER */

.footer{
background:#020617;
text-align:center;
padding:18px;
font-size:13px;
color:#94a3b8;
border-top:1px solid rgba(255,255,255,0.08);
}

/* MOBILE */

@media(max-width:900px){

.wrapper{
flex-direction:column;
}

.sidebar{
width:100%;
display:flex;
justify-content:space-around;
}

.main{
padding:25px;
}

}

</style>
</head>

<body>

<!-- NAVBAR -->

<div class="navbar">

<div class="logo">🎓 Campus Assistant</div>

<div class="nav-links">
<a href="/">Home</a>
<a href="/busform">Bus Concession</a>

<% if(user){ %>
<a href="/dashboard">Dashboard</a>
<a href="/logout">Logout</a>
<% } else { %>
<a href="/auth/google">Login</a>
<% } %>

</div>

</div>


<!-- PAGE CONTENT -->

<div class="wrapper">

<div class="sidebar">

<h2>Dashboard</h2>

<a href="/dashboard">Dashboard</a>
<a href="/assignments">Assignments</a>
<a href="/allcourses">Courses</a>
<a href="/results">Results</a>
<a href="/notes">Notes Hub</a>
<a href="/notes/browse">Browse</a>
<a href="/upload-notes">Upload</a>

</div>


<div class="main">

<div class="header">

<h1>📚 Your Courses</h1>

<div class="profile">
<img src="<%= user.photos?.[0]?.value || 'https://via.placeholder.com/40' %>">
</div>

</div>

<div class="courses-grid">

<% courses.forEach(course => { %>

<div class="course-card">

<div class="course-header">

<div>
<div class="course-title"><%= course.name %></div>
<div class="course-section"><%= course.section || "No Section" %></div>
</div>

<img src="<%= course.teacherPhoto || 'https://i.pravatar.cc/100' %>" class="professor">

</div>

<div class="course-body">

<div class="stats">
<span>📄 <%= course.total %> Tasks</span>
<span>⏳ <%= course.pending %></span>
<span>✅ <%= course.completed %></span>
</div>

<div class="progress-wrap">
<div class="progress-bar" style="width:<%= course.progress || 0 %>%"></div>
</div>

<div class="actions">

<a href="/assignments?course=<%= course.name %>" class="btn btn-primary">
View Tasks
</a>

<a href="<%= course.alternateLink %>" target="_blank" class="btn btn-secondary">
Open Classroom
</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>

</div>


<!-- FOOTER -->

<div class="footer">
© 2026 Campus Assistant • Built for Students 🚀
</div>

</body>
</html>