<!DOCTYPE html>
<html>

<head>
<title>Campus Assistant | Courses</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Inter',sans-serif;
background:#0f172a;
color:#e2e8f0;
min-height:100vh;
display:flex;
flex-direction:column;
}

/* NAVBAR */

.navbar{
background:#020617;
padding:16px 40px;
display:flex;
justify-content:space-between;
align-items:center;
border-bottom:1px solid rgba(255,255,255,0.05);
}

.logo{
font-size:18px;
font-weight:600;
color:#6366f1;
}

.nav-links{
display:flex;
gap:20px;
}

.nav-links a{
text-decoration:none;
font-size:14px;
color:#94a3b8;
}

.nav-links a:hover{
color:white;
}

/* CONTAINER */

.container{
max-width:1200px;
margin:auto;
padding:40px 20px;
flex:1;
width:100%;
}

h1{
font-size:28px;
margin-bottom:35px;
}

/* GRID */

.courses-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:25px;
}

/* CARD */

.course-card{
background:#020617;
border-radius:16px;
overflow:hidden;
border:1px solid rgba(255,255,255,0.05);
transition:.3s;
}

.course-card:hover{
transform:translateY(-6px);
border-color:#6366f1;
}

/* HEADER */

.course-header{
padding:20px;
display:flex;
justify-content:space-between;
align-items:center;
color:white;
background:linear-gradient(135deg,#6366f1,#4f46e5);
}

.course-info h3{
font-size:18px;
}

.course-info p{
font-size:13px;
opacity:0.9;
}

/* PROFESSOR IMAGE */

.professor{
width:38px;
height:38px;
border-radius:50%;
border:2px solid rgba(255,255,255,0.4);
object-fit:cover;
}

/* BODY */

.course-body{
padding:20px;
}

/* STATS */

.stats{
display:flex;
justify-content:space-between;
font-size:13px;
margin-bottom:15px;
color:#cbd5f5;
}

/* PROGRESS */

.progress-wrap{
height:8px;
background:rgba(255,255,255,0.1);
border-radius:10px;
overflow:hidden;
margin-bottom:18px;
}

.progress-bar{
height:8px;
background:linear-gradient(90deg,#6366f1,#22d3ee);
}

/* BUTTONS */

.actions{
display:flex;
gap:10px;
}

.btn{
flex:1;
text-align:center;
padding:8px;
border-radius:10px;
font-size:13px;
text-decoration:none;
}

.btn-primary{
background:linear-gradient(135deg,#6366f1,#4f46e5);
color:white;
}

.btn-secondary{
background:rgba(255,255,255,0.08);
color:white;
}

.btn-primary:hover{
transform:translateY(-2px);
}

.btn-secondary:hover{
background:rgba(255,255,255,0.15);
}

/* FOOTER */

.footer{
text-align:center;
padding:18px;
font-size:13px;
background:#020617;
border-top:1px solid rgba(255,255,255,0.05);
color:#94a3b8;
}

/* MOBILE */

@media(max-width:768px){

.navbar{
padding:15px 20px;
}

.nav-links{
gap:12px;
font-size:13px;
}

.container{
padding:30px 15px;
}

}

</style>
</head>

<body>

<!-- NAVBAR -->

<div class="navbar">

<div class="logo">🎓 Campus Assistant</div>

<div class="nav-links">

<a href="/">Home</a>
<a href="/busform">Bus Concession</a>

<% if(user){ %>
<a href="/dashboard">Dashboard</a>
<a href="/logout">Logout</a>
<% } else { %>
<a href="/auth/google">Login</a>
<% } %>

</div>

</div>


<!-- MAIN -->

<div class="container">

<h1>📚 Your Courses</h1>

<div class="courses-grid">

<% courses.forEach(course=> { %>

<div class="course-card">

<div class="course-header"

style="<%= course.backgroundImageUrl 
? `background:url('${course.backgroundImageUrl}') center/cover`
: `background:${course.backgroundColor || 'linear-gradient(135deg,#6366f1,#4f46e5)'}` %>">

<div class="course-info">

<h3><%= course.name %></h3>

<p><%= course.section || "No Section" %></p>

</div>

<!-- RANDOM PROFESSOR AVATAR -->

<img 
src="<%= course.teacherPhoto || `https://api.dicebear.com/7.x/initials/svg?seed=${course.name}` %>" 
class="professor">

</div>

<div class="course-body">

<div class="stats">

<span>📄 <%= course.total %> Tasks</span>
<span>⏳ <%= course.pending %></span>
<span>✅ <%= course.completed %></span>

</div>

<div class="progress-wrap">

<div class="progress-bar" style="width:<%= course.progress || 0 %>%"></div>

</div>

<div class="actions">

<a href="/assignments?course=<%= course.name %>" class="btn btn-primary">
View Tasks
</a>

<a href="<%= course.alternateLink %>" target="_blank" class="btn btn-secondary">
Open Classroom
</a>

</div>

</div>

</div>

<% }) %>

</div>

</div>


<!-- FOOTER -->

<div class="footer">

© 2026 Campus Assistant • Built for Students 🚀

</div>

</body>
</html>